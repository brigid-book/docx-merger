@isTest
private class DocxMergerTest {
    
    @testSetup
    static void setup() {
        
        Account acc = new Account(
        	Name = 'Bobson',
			Phone = '(123)456-7890'
        );
        insert acc;
        
        String wordDocBase64 = '';
        Blob wordDocBlob = EncodingUtil.Base64Decode(wordDocBase64);
        
        Map<String,String> mergeFields = new Map<String,String>{
            '{{ mergefield }}' =>  'I HAVE BEEN MERGED',
            '{{ header1 }}' =>  'NEW HEADER 1',
            '{{ header2 }}' =>  'NEW HEADER 2'
        };
        
        DocxMerger merger = new DocxMerger();
    	merger.mergeDoc(wordDocBlob, acc.id, mergeFields, 'merged document');
        
    }
	
    @isTest
    static void newDocumentIsCreated() {
        
        ContentDocument newDocument = [SELECT Id, Title, LatestPublishedVersionId FROM ContentDocument WHERE Title = 'merged document'] ?? null;
        Assert.isNotNull(newDocument, 'Newly created document could not be found');
        
    }
    
}